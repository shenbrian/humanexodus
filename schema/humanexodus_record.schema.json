{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/shenbrian/humanexodus/schema/humanexodus_record.schema.json",
  "title": "HumanExodus Repositioning Record",
  "description": "A single repositioning event capturing AI-induced pressure, human response, and observed outcome. The atomic unit of the Human Adaptation Graph.",
  "version": "0.2",
  "type": "object",

  "required": [
    "record_id",
    "person_id",
    "submitted_at",
    "entry_type",
    "role",
    "pressure",
    "workflow_change",
    "response",
    "outcome",
    "narrative",
    "meta"
  ],

  "properties": {

    "record_id": {
      "type": "string",
      "description": "Unique identifier for this record. Format: HX-SE-XXXXXX for engineer records.",
      "examples": ["HX-SE-000001"]
    },

    "person_id": {
      "type": "string",
      "description": "Pseudonymous contributor identifier. Never a real name or email.",
      "pattern": "^PSEUDO-[A-Z0-9]{4}$",
      "examples": ["PSEUDO-8F3A"]
    },

    "submitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of submission."
    },

    "entry_type": {
      "type": "string",
      "enum": ["initial", "update", "reflection"],
      "description": "Whether this is a first submission, an update to a prior record, or a retrospective reflection."
    },

    "linked_record_id": {
      "type": "string",
      "description": "Required for entry_type=update or reflection. References the original record.",
      "examples": ["HX-SE-000001"]
    },

    "role": {
      "type": "object",
      "required": ["level", "title", "focus_area", "years_experience"],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "student",
            "junior",
            "mid",
            "senior",
            "lead",
            "staff",
            "principal",
            "manager",
            "independent",
            "founder",
            "unknown"
          ],
          "description": "Career level at time of submission."
        },
        "title": {
          "type": "string",
          "description": "Actual role title. Be specific.",
          "examples": ["Backend Engineer", "Senior Consultant", "QA Engineer"]
        },
        "focus_area": {
          "type": "string",
          "enum": [
            "backend",
            "frontend",
            "fullstack",
            "mobile",
            "infra",
            "devops",
            "data",
            "ml",
            "security",
            "embedded",
            "qa",
            "other"
          ],
          "description": "Primary technical focus area."
        },
        "years_experience": {
          "type": "string",
          "description": "Years of professional experience as a range.",
          "examples": ["0-1", "0-2", "3-5", "6-8", "9+"]
        }
      }
    },

    "stack": {
      "type": "object",
      "description": "Technical stack at time of submission.",
      "properties": {
        "languages": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Programming languages used.",
          "examples": [["Python", "TypeScript"]]
        },
        "frameworks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Frameworks, tools, and platforms used.",
          "examples": [["FastAPI", "Node.js", "Kubernetes"]]
        },
        "environment": {
          "type": "string",
          "enum": ["cloud", "on_prem", "hybrid", "startup", "enterprise", "unknown"],
          "description": "Working environment."
        }
      }
    },

    "pressure": {
      "type": "object",
      "required": ["pressure_type", "signals", "severity_self_assessed", "time_first_noticed"],
      "properties": {
        "pressure_type": {
          "type": "string",
          "enum": [
            "replacement_pressure",
            "augmentation_pressure",
            "productivity_pressure",
            "skill_shift",
            "scope_reduction",
            "scope_expansion",
            "tooling_disruption",
            "hiring_signal_change",
            "opportunity_emergence",
            "organizational_restructuring",
            "unclear"
          ],
          "description": "The primary type of AI-induced pressure experienced."
        },
        "source": {
          "type": "string",
          "enum": [
            "layoff_event",
            "manager_signal",
            "client_behavior",
            "workflow_change",
            "tool_adoption",
            "market_observation",
            "peer_observation",
            "self_inference",
            "public_news",
            "unclear"
          ],
          "description": "Where the pressure signal originated."
        },
        "signals": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Concrete observed signals. Be specific — not opinions.",
          "examples": [
            ["Copilot used in code reviews", "AI-generated PRs increasing", "Faster sprint expectations"]
          ]
        },
        "severity_self_assessed": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "1 = minor signal, 5 = existential threat to current role."
        },
        "time_first_noticed": {
          "type": "string",
          "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$",
          "description": "Month and year pressure first noticed. Format: YYYY-MM.",
          "examples": ["2026-02"]
        },
        "confidence_self_assessed": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "How confident are you this pressure is real and significant? 1 = uncertain, 5 = highly confident."
        }
      }
    },

    "workflow_change": {
      "type": "object",
      "required": ["before", "after"],
      "description": "The most important field. Captures what actually changed in day-to-day work.",
      "properties": {
        "before": {
          "type": "string",
          "description": "How you worked before AI pressure changed your workflow. Be specific.",
          "examples": ["Wrote most service logic and tests manually, debugging done through docs and team discussion."]
        },
        "after": {
          "type": "string",
          "description": "How you work now. Be specific.",
          "examples": ["Uses AI for scaffolding endpoints and generating test cases, more time on API design and trade-offs."]
        },
        "ai_tools_used": {
          "type": "array",
          "items": { "type": "string" },
          "description": "AI tools that changed your workflow.",
          "examples": [["GitHub Copilot", "ChatGPT", "Cursor"]]
        }
      }
    },

    "response": {
      "type": "object",
      "required": ["response_type", "actions"],
      "description": "The repositioning action taken in response to the pressure.",
      "properties": {
        "response_type": {
          "type": "string",
          "enum": [
            "tool_adoption",
            "reskilling",
            "upskilling",
            "role_shift",
            "team_shift",
            "managerial_transition",
            "entrepreneurship",
            "portfolio_career",
            "wait_and_observe",
            "resistance",
            "relocation",
            "other"
          ],
          "description": "Primary type of response taken."
        },
        "actions": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Concrete actions taken. Be specific.",
          "examples": [["Started using AI tools in project scoping", "Shifted focus toward client-facing synthesis"]]
        },
        "intent": {
          "type": "string",
          "enum": [
            "increase_leverage",
            "preserve_role",
            "avoid_risk",
            "explore_new_path",
            "reduce_dependency",
            "unclear"
          ],
          "description": "The underlying intent behind the response."
        }
      }
    },

    "outcome": {
      "type": "object",
      "required": ["status"],
      "description": "The current or final outcome of the repositioning.",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "in_progress",
            "stabilized",
            "improved_position",
            "role_changed",
            "role_lost",
            "burnout_increase",
            "income_reduced",
            "income_improved",
            "unclear"
          ],
          "description": "Current outcome status."
        },
        "early_effect": {
          "type": "string",
          "description": "What has happened so far. Be honest — imperfect clarity is fine.",
          "maxLength": 500
        },
        "confidence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "How confident are you in this outcome assessment?"
        }
      }
    },

    "narrative": {
      "type": "object",
      "required": ["summary"],
      "description": "Short contextual framing. Makes the record recognisable to others in similar situations.",
      "properties": {
        "summary": {
          "type": "string",
          "description": "Two to four sentences. What made this situation specific to you? Write calmly and observationally.",
          "maxLength": 600
        },
        "path_next_considered": {
          "type": "string",
          "description": "What are you considering doing next? Optional.",
          "maxLength": 300
        }
      }
    },

    "meta": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "submission_mode": {
          "type": "string",
          "enum": ["tool", "manual", "api"],
          "description": "How was this record submitted?"
        },
        "visibility": {
          "type": "string",
          "enum": ["public_pseudonymous", "private"],
          "default": "public_pseudonymous"
        },
        "version": {
          "type": "string",
          "description": "Schema version used for this record.",
          "examples": ["0.2"]
        }
      }
    }
  },

  "if": {
    "properties": { "entry_type": { "enum": ["update", "reflection"] } }
  },
  "then": {
    "required": ["linked_record_id"]
  }
}